{erl_opts, [debug_info]}.

{project_plugins, [
    {shurbej_gen_schema, {path, "plugins/shurbej_gen_schema"}}
]}.

{provider_hooks, [
    {pre, [{compile, gen_schema}]}
]}.

{dialyzer, [
    {plt_extra_apps, [mnesia, cowlib]}
]}.

{deps, [
    {cowboy, "2.12.0"},
    {simdjsone, "0.5.0"}
]}.

{relx, [
    {release, {shurbej, "0.1.0"}, [
        mnesia,
        shurbej_store,
        shurbej_web,
        shurbej,
        sasl
    ]},

    {mode, dev},

    {sys_config, "./config/sys.config"},
    {vm_args_src, "./config/vm.args.src"}
]}.

{cover_enabled, true}.
{cover_opts, [verbose]}.

{profiles, [
    {test, [
        {deps, [{gun, "2.1.0"}]}
    ]},
    {prod, [
        {relx, [
            {mode, prod}
        ]}
    ]}
]}.
